# ============================================================
# DrishtiAI — environment variable template
# Copy to .env and fill in values. chmod 600 .env
# Never commit .env to git.
# ============================================================

# ---- Postgres ----
POSTGRES_USER=drishtiai
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=drishtiai
DATABASE_URL=postgresql+psycopg://drishtiai:change-me-strong-password@postgres:5432/drishtiai

# ---- Django ----
DJANGO_SECRET_KEY=change-me-50-chars-random-string
DJANGO_DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- FastAPI ----
API_SECRET_KEY=change-me-50-chars-random-string
API_CORS_ORIGINS=http://localhost:3000

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- MinIO ----
MINIO_ROOT_USER=drishtiai
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=drishtiai
MINIO_SECRET_KEY=change-me-strong-password
MINIO_SECURE=false
# Presigned URL TTL in seconds (default 900 = 15 min)
MINIO_PRESIGNED_TTL_SECONDS=900

# ---- JWT (RS256) ----
# Generate with: make keygen
# The script outputs single-line PEM values with \n literals — paste them here.
JWT_PRIVATE_KEY_PEM=<run-make-keygen>
JWT_PUBLIC_KEY_PEM=<run-make-keygen>
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Next.js ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ---- Pipeline ----
PIPELINE_GPU_ID=0
PIPELINE_LOG_LEVEL=INFO
# Comma-separated camera UUIDs to process, or "all" for every enabled camera
PIPELINE_CAMERA_IDS=all
# Sample 1 frame every N frames (reduce CPU load; 5 = ~5fps from 25fps stream)
PIPELINE_FRAME_SAMPLE=5
# Suppress duplicate plate reads within this window (seconds)
PIPELINE_DEDUP_SECONDS=5
# Multi-frame voter: accumulate reads for this many seconds before emitting consensus
PIPELINE_VOTER_WINDOW_S=4.0
PIPELINE_VOTER_EXIT_GAP_S=1.5
PIPELINE_VOTER_MIN_READS=2
# Capture backend: "gstreamer" (default) or "opencv"
PIPELINE_CAPTURE_BACKEND=gstreamer

# ---- OCR (Phase 11) ----
# Enable GPU acceleration for PaddleOCR (requires CUDA + paddle-gpu)
PIPELINE_OCR_USE_GPU=false
# Two-stage: detect plate candidates via OpenCV first, then OCR on crops
PIPELINE_OCR_TWO_STAGE=true
# Apply CLAHE + unsharp-mask preprocessing before OCR
PIPELINE_OCR_PREPROCESS=true

# ---- Seeding ----
SUPERADMIN_EMAIL=admin@drishtiai.local
SUPERADMIN_PASSWORD=change-me-strong-password
# RTSP source for the dev test camera (used by seed-dev target)
RTSP_URL=rtsp://mediamtx:8554/test

# ---- Site / installation ----
SITE_NAME=DrishtiAI Installation
SITE_TIMEZONE=Asia/Kathmandu

# ---- MFA / TOTP ----
# No config needed — users enroll via /auth/mfa/setup after login.

# ---- Gate credentials encryption ----
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to skip encryption (dev only — plaintext stored in DB)
GATE_CREDENTIAL_KEY=<generated-at-install>

# ---- Observability ----
# REQUIRED: set a strong random password — "admin" is rejected at startup
GRAFANA_PASSWORD=<generated-at-install>
